# Backend Port Configuration
PORT=3000

# PostgreSQL Connection String (for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/ironing_db?schema=public"

# JWT Authentication Config
JWT_SECRET="replace_with_a_secure_jwt_secret_phrase"

# WhatsApp Cloud API Credentials
WHATSAPP_TOKEN="your_meta_system_user_access_token"
PHONE_ID="your_whatsapp_phone_number_id"
WEBHOOK_VERIFY_TOKEN="your_custom_webhook_verify_token"

# Razorpay Payment Gateway Credentials
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
