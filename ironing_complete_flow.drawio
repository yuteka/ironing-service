          <mxGeometry x="60" y="500" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_count" value="Bot: How many clothes?&#10;→ Min 5 check&#10;→ Pickup date/time&#10;→ Confirm summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;" vertex="1" parent="1">
