          <mxGeometry x="680" y="1100" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_msgformat" value="Message ALWAYS includes Order ID:&#10;&quot;Order #12346 is Ready for pickup!&quot;&#10;NOT just &quot;Your order is ready!&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
