        <mxCell id="n_admin1" value="#12345 → Partner Ravi&#10;currently Ironing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4DAF5;strokeColor=#9B82D1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1030" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n_admin2" value="#12346 → Partner Kumar&#10;assigned for pickup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4DAF5;strokeColor=#9B82D1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="1030" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n_admin3" value="#12347 → not yet assigned&#10;(just placed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4DAF5;strokeColor=#9B82D1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="1030" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="rule4" value="RULE 4: Each order is assigned, tracked, and resolved on its own timeline.&#10;A delay or issue on #12345 has zero effect on #12346 or #12347." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=12;fontStyle=1;dashed=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="1130" width="600" height="60" as="geometry" />
        </mxCell>

        <!-- ============ EDGE CASES SECTION ============ -->
        <mxCell id="edge_title" value="Edge Cases — All Explicitly Handled" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#21295C;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="1340" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="edge1_q" value="What if customer places 2 orders&#10;with the SAME pickup slot today?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1390" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge1_a" value="Allowed. Each order is independent.&#10;Admin can assign the SAME partner&#10;to do both pickups in one visit&#10;(manual admin convenience),&#10;or two different partners." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="1390" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="edge2_q" value="What if customer wants to cancel&#10;ONE order but keep the other?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1510" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge2_a" value="No problem. Cancel button is shown&#10;PER ORDER (via Check Order screen).&#10;Cancelling #12347 has zero effect&#10;on #12345 or #12346." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="1510" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="edge3_q" value="What if payment is due on #12345&#10;while #12346 is still being ironed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1630" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge3_a" value="Payment is requested PER ORDER&#10;at its own &quot;Ready&quot; stage. #12345&#10;can be paid and delivered while&#10;#12346 is still in the shop." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="1630" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="edge4_q" value="What if customer's number changes&#10;between order #1 and order #2?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1750" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge4_a" value="New number = New customer record&#10;(system can't auto-link). Old order&#10;history stays under old number.&#10;Admin can manually merge if needed." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="1750" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="edge5_q" value="What if a damage issue is found&#10;on #12346 — does it pause #12347?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="1390" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge5_a" value="No. The dispute/accept flow is scoped&#10;ONLY to #12346. #12347 continues&#10;through its own stages completely&#10;unaffected." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="1390" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="edge6_q" value="What if NO pickup partner is&#10;available for one of the orders?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="1510" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge6_a" value="That ONE order stays in&#10;&quot;Unassigned&quot; queue, flagged for&#10;admin. Other orders for the same&#10;(or different) customer are&#10;processed normally, no delay." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="1510" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="edge7_q" value="What if customer messages &quot;Hi&quot;&#10;while an order is already active?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="1630" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="edge7_a" value="Bot still replies &quot;Welcome back&quot;&#10;and shows the normal menu — having&#10;an active order never restricts&#10;menu access or starts a different flow." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="980" y="1630" width="300" height="90" as="geometry" />
        </mxCell>

        <!-- ============ FINAL SUMMARY BANNER ============ -->
        <mxCell id="summary" value="CORE PRINCIPLE: Every order is a fully independent record from creation to delivery.&#10;No step in the system ever checks &quot;does this customer have another order&quot; before proceeding.&#10;The only shared element is the customer's phone number used to look them up — nothing else is shared or blocked." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#21295C;strokeColor=#21295C;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1860" width="1220" height="90" as="geometry" />
        </mxCell>

