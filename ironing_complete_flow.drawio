        <mxCell id="db_note" value="Same phone number → multiple independent rows.&#10;Each row has its own status, never linked or blocked by another." style="text;html=1;fontSize=12;fontColor=#5C7080;align=left;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="700" y="730" width="520" height="40" as="geometry" />
