        <!-- ============ ADMIN SIDE - PARALLEL PROCESSING ============ -->
        <mxCell id="admin_title" value="Admin Side — Orders Processed Independently" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#21295C;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="980" width="600" height="30" as="geometry" />
