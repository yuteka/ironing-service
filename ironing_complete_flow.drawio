          <mxGeometry x="680" y="860" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_showall" value="Bot shows ALL active orders&#10;(status before Delivered),&#10;each with its own Order ID&#10;clearly labeled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="960" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="rule3" value="RULE 3: Status display always shows&#10;Order ID first. Customer never has to&#10;guess which order an update refers to." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=12;fontStyle=1;dashed=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="960" width="280" height="90" as="geometry" />
        </mxCell>

