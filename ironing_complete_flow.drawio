          <mxGeometry x="60" y="730" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- ============ RULE 2 ============ -->
        <mxCell id="rule2" value="RULE 2: Every order gets its own unique&#10;Order ID. Existing orders (any status)&#10;are never touched, paused, or affected&#10;by a new order being placed." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=12;fontStyle=1;dashed=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="730" width="320" height="90" as="geometry" />
        </mxCell>

        <mxCell id="n_back" value="Returns to Main Menu&#10;(can place ANOTHER order&#10;immediately, no wait)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;" vertex="1" parent="1">
