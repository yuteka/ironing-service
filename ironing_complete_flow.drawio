        <mxCell id="db_row4" value="#12200 | 98765xxxxx | Delivered (past order)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD9E0;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="684" width="520" height="36" as="geometry" />
