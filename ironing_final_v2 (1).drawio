        <mxCell id="n_recount" value="Customer disputes count&#xa;-&gt; Partner: Recount&#xa;-&gt; New count&#xa;-&gt; New payment request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4D6;strokeColor=#C55A11;fontSize=11;dashed=1;" vertex="1" parent="1"><mxGeometry x="610" y="2290" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="n_timeout_pay" value="30 min no payment&#xa;-&gt; 1 reminder sent&#xa;-&gt; Still no pay&#xa;-&gt; Admin notified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4D6;strokeColor=#C55A11;fontSize=11;dashed=1;" vertex="1" parent="1"><mxGeometry x="870" y="2320" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="n_picked" value="Partner taps PICKED&#xa;(only after payment)&#xa;Clothes collected -&gt; go to shop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#E0A86B;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1130" y="2260" width="240" height="70" as="geometry"/></mxCell>

        <!-- ===== SEC 8: STATUS + INVOICE ===== -->
        <mxCell id="s8" value="8.  STATUS UPDATES + INVOICE" style="text;html=1;fontSize=15;fontStyle=1;fontColor=#FFFFFF;fillColor=#21295C;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="2430" width="500" height="28" as="geometry"/></mxCell>
        <mxCell id="n_status" value="Automatic WhatsApp push per stage (ALWAYS includes Order ID):&#xa;Confirmed -&gt; Pickup Assigned -&gt; Collected -&gt; Reached Shop&#xa;-&gt; Ironing Started -&gt; Ready -&gt; Out for Delivery -&gt; Delivered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="2475" width="720" height="75" as="geometry"/></mxCell>
        <mxCell id="n_invoice" value="After delivery:&#xa;&quot;Order #12346 delivered ✅&#xa;[Download Invoice]&quot;&#xa;PDF: items, total, PAID, date" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=12;align=left;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="40" y="2575" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="rule_status" value="RULE: Payment already done at pickup. No payment at delivery. Invoice is receipt only." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="360" y="2595" width="400" height="40" as="geometry"/></mxCell>

        <!-- ===== SEC 9: POST DELIVERY ===== -->
        <mxCell id="s9" value="9.  POST-DELIVERY SUPPORT" style="text;html=1;fontSize=15;fontStyle=1;fontColor=#FFFFFF;fillColor=#21295C;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="2695" width="400" height="28" as="geometry"/></mxCell>
        <mxCell id="n_postdmg" value="Customer reports damage&#xa;after delivery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBDDE7;strokeColor=#D98AA8;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="2740" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="n_admresolve" value="Admin uploads photo,&#xa;customer notified,&#xa;Call Us -&gt; manual resolution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4DAF5;strokeColor=#9B82D1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="280" y="2740" width="220" height="60" as="geometry"/></mxCell>
        <mxCell id="rule_post" value="RULE: Post-delivery dispute NEVER blocks or re-opens any other order — even one placed minutes later." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="40" y="2820" width="700" height="40" as="geometry"/></mxCell>

        <!-- ===== SEC 10: DB STATE ===== -->
        <mxCell id="s10" value="10.  DATABASE — MULTIPLE ORDERS, SAME CUSTOMER" style="text;html=1;fontSize=15;fontStyle=1;fontColor=#FFFFFF;fillColor=#21295C;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="2880" width="700" height="28" as="geometry"/></mxCell>
        <mxCell id="db0" value="Order ID  |  Customer Phone  |  Status  |  Partner  |  Payment Status" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#21295C;strokeColor=#21295C;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="2925" width="900" height="36" as="geometry"/></mxCell>
        <mxCell id="db1" value="#12345  |  98765xxxxx  |  Ironing Started  |  Ravi  |  PAID (at pickup)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F9FB;strokeColor=#CBD9E0;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="2961" width="900" height="36" as="geometry"/></mxCell>
        <mxCell id="db2" value="#12346  |  98765xxxxx  |  Pickup Assigned  |  Kumar  |  PAID (at pickup)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD9E0;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="2997" width="900" height="36" as="geometry"/></mxCell>
        <mxCell id="db3" value="#12347  |  98765xxxxx  |  Order Confirmed  |  Unassigned  |  PENDING (not yet picked up)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F9FB;strokeColor=#CBD9E0;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="3033" width="900" height="36" as="geometry"/></mxCell>
        <mxCell id="db4" value="#12200  |  98765xxxxx  |  Delivered  |  Ravi  |  PAID + Invoice sent" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD9E0;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="3069" width="900" height="36" as="geometry"/></mxCell>
        <mxCell id="db_note" value="Same phone number — 4 independent rows. Payment collected at pickup for each. No row ever blocks another." style="text;html=1;fontSize=12;fontColor=#5C7080;align=left;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="40" y="3115" width="900" height="36" as="geometry"/></mxCell>

        <!-- ===== SUMMARY ===== -->
        <mxCell id="summary" value="V2 CHANGES: (1) Partner login = Username + Password — admin deletes account for instant revoke. No expiring links.&#xa;(2) Cloth condition check happens BEFORE pre-payment count — customer accepts issues first, THEN partner counts + payment requested.&#xa;CORE: Nothing ever blocks. Pre-payment mandatory before pickup. Payment based on ACTUAL partner count." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#21295C;strokeColor=#21295C;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=14;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="40" y="3170" width="1900" height="90" as="geometry"/></mxCell>

