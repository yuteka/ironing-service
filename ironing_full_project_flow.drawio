        </mxCell>
        <mxCell id="sec9" parent="1" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#FFFFFF;align=left;spacingLeft=8;fillColor=#21295C;" value="9. POST-DELIVERY SUPPORT" vertex="1">
          <mxGeometry height="32" width="500" x="800" y="1920" as="geometry" />
        </mxCell>
        <mxCell id="n_postdmg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBDDE7;strokeColor=#D98AA8;fontSize=12;" value="Customer reports damage&#xa;AFTER delivery (separate from&#xa;pre-pickup check)" vertex="1">
          <mxGeometry height="70" width="240" x="800" y="1970" as="geometry" />
        </mxCell>
        <mxCell id="n_admdmgresolve" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4DAF5;strokeColor=#9B82D1;fontSize=12;" value="Admin uploads photo,&#xa;customer notified,&#xa;Call Us -&gt; manual resolution" vertex="1">
          <mxGeometry height="70" width="240" x="1080" y="1970" as="geometry" />
        </mxCell>
        <mxCell id="rule_postdmg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6F2E0;strokeColor=#2E8B57;fontSize=11;fontStyle=1;dashed=1;align=left;spacingLeft=8;" value="RULE: A post-delivery dispute on #12345 never re-opens, blocks,&#xa;or delays any other order - even a brand new order placed minutes later." vertex="1">
          <mxGeometry height="50" width="520" x="800" y="2060" as="geometry" />
        </mxCell>
        <mxCell id="sec10" parent="1" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#FFFFFF;align=left;spacingLeft=8;fillColor=#21295C;" value="10. EDGE CASES - ALL EXPLICITLY HANDLED" vertex="1">
          <mxGeometry height="32" width="600" x="40" y="2300" as="geometry" />
        </mxCell>
        <mxCell id="edge1_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="2 orders, SAME pickup&#xa;slot today?" vertex="1">
          <mxGeometry height="80" width="220" x="40" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge1_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="Allowed. Admin can assign the&#xa;same partner to do both pickups&#xa;in one visit, or two partners." vertex="1">
          <mxGeometry height="80" width="280" x="280" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge2_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="Cancel ONE order,&#xa;keep the other?" vertex="1">
          <mxGeometry height="80" width="220" x="40" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge2_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="No problem - Cancel button is&#xa;per-order via Check Order screen.&#xa;Zero effect on other orders." vertex="1">
          <mxGeometry height="80" width="280" x="280" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge3_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="Customer number changes&#xa;between orders?" vertex="1">
          <mxGeometry height="80" width="220" x="40" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="edge3_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="New number = new customer&#xa;record. Old history stays under&#xa;old number; admin can merge manually." vertex="1">
          <mxGeometry height="80" width="280" x="280" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="edge4_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="&quot;Hi&quot; sent while an order&#xa;is already active?" vertex="1">
          <mxGeometry height="80" width="220" x="640" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge4_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="Bot replies &quot;Welcome back&quot; and&#xa;shows the normal menu. An active&#xa;order never restricts menu access." vertex="1">
          <mxGeometry height="80" width="280" x="880" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge5_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="No pickup partner available&#xa;for one order?" vertex="1">
          <mxGeometry height="80" width="220" x="640" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge5_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="That order stays &quot;Unassigned&quot;,&#xa;flagged for admin. Other orders&#xa;(same/different customer) proceed normally." vertex="1">
          <mxGeometry height="80" width="280" x="880" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge6_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="Damage found on one order&#xa;- pauses other orders?" vertex="1">
          <mxGeometry height="80" width="220" x="640" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="edge6_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="No. The dispute/accept flow is&#xa;scoped only to that Order ID.&#xa;All others continue unaffected." vertex="1">
          <mxGeometry height="80" width="280" x="880" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="edge7_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="Payment due on one order&#xa;while another still ironing?" vertex="1">
          <mxGeometry height="80" width="220" x="1240" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge7_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="Payment requested per order at&#xa;its own &quot;Ready&quot; stage. One order&#xa;can be paid/delivered independently." vertex="1">
          <mxGeometry height="80" width="280" x="1480" y="2350" as="geometry" />
        </mxCell>
        <mxCell id="edge8_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="One partner unavailable&#xa;mid-day - other jobs?" vertex="1">
          <mxGeometry height="80" width="220" x="1240" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge8_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="Only that partner&#39;s remaining&#xa;jobs get reassigned. Other partners&#39;&#xa;schedules are completely unaffected." vertex="1">
          <mxGeometry height="80" width="280" x="1480" y="2450" as="geometry" />
        </mxCell>
        <mxCell id="edge9_q" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" value="Post-delivery complaint on&#xa;an old order - blocks new orders?" vertex="1">
          <mxGeometry height="80" width="220" x="1240" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="edge9_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEBFB;strokeColor=#6FA8DC;fontSize=11;align=left;spacingLeft=8;" value="No. Customer can place and&#xa;receive new orders while an old&#xa;dispute ticket is still open." vertex="1">
          <mxGeometry height="80" width="280" x="1480" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="summary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#21295C;strokeColor=#21295C;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=left;spacingLeft=14;spacingTop=10;" value="CORE PRINCIPLE - NOTHING EVER BLOCKS: Every order is a fully independent record from creation to delivery, with its own ID, status,&#xa;partner assignment, dispute thread, and payment. No step anywhere in the system checks &quot;does this customer have another order&quot; before proceeding.&#xa;The only shared element across orders is the customer&#39;s phone number used for lookup - nothing else is shared, paused, or dependent." vertex="1">
